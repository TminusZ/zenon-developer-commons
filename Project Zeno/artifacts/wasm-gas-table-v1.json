{
  "artifact": "wasm-gas-table-v1",
  "metering_version": 1,
  "runtime_profile": "WebAssembly Core 1.0 MVP (integer subset)",
  "excluded_from_metering": {
    "reason": "rejected by the deployment validation pipeline (SPEC.md §7.2, §11.3) and therefore never metered",
    "categories": [
      "all f32.* and f64.* floating-point instructions",
      "all v128 SIMD instructions",
      "all threads/atomics instructions",
      "all WASI imports",
      "sign-extension operators i32.extend8_s/i32.extend16_s/i64.extend8_s/i64.extend16_s/i64.extend32_s (outside strict Core 1.0 MVP)",
      "saturating float-to-int conversions (trunc_sat, outside strict Core 1.0 MVP)"
    ]
  },
  "unit": "L2 gas (plasma) units",
  "cost_principles": [
    "1 = trivial: consts, locals, simple integer add/sub/bitwise/shift/rotate, comparisons",
    "2 = light: loads/stores, mul, clz/ctz/popcnt, global access, select, integer conversions, memory.size",
    "5 = integer div/rem (variable-latency) and memory.grow base",
    "branch/call overhead modeled explicitly (br/br_if/br_table=2, return=2, call=5, call_indirect=10)"
  ],
  "block_metering": {
    "model": "basic-block charge injection",
    "rule": "Gas for straight-line instructions MUST be summed per basic block and decremented once at block entry (the standard fuel model). The observable cost of executing a basic block MUST equal the sum of its instructions' table costs. Branch/call costs are the costs of the branch/call instructions themselves.",
    "note": "Instrumentation is deterministic (SPEC.md §11.3). Two implementations MUST decrement identical totals for identical executed basic-block sequences."
  },
  "memory_model": {
    "wasm_page_bytes": 65536,
    "memory_grow_base": 5,
    "memory_grow_per_page": 1000,
    "note": "memory.grow base is in the opcode table; per-page surcharge here. Initial memory declared at instantiation is charged as memory_grow_per_page * initial_pages against the input budget before execution begins."
  },
