  "surcharges": {
    "br_table": {
      "per_target_entry": 1,
      "note": "total = base(2) + 1 per branch target in the table (including the default)."
    },
    "memory.grow": {
      "per_page": 1000,
      "note": "total = base(5) + 1000 * delta_pages. A grow that would exceed MaxMemory returns -1 and charges only the base(5); no per-page charge for the rejected pages. One page = 65536 bytes."
    },
    "call_indirect": {
      "note": "base 10 covers table bounds check + type check + dispatch."
    }
  },
  "host_functions": {
    "storage_len": {
      "base": 100,
      "per_32_bytes": 0,
      "note": "fixed base cost; key length is bounded by MaxStateKeySize=32 so no per-byte term."
    },
    "storage_read": {
      "base": 200,
      "per_32_bytes": 10,
      "note": "total = 200 + 10 * ceil(value_bytes/32). Charged on the value actually read; an absent key (returns -1) charges base only."
    },
    "abort": {
      "base": 1,
      "per_32_bytes": 0,
      "note": "minimal fixed cost; halts execution."
    }
  },
  "post_execution_effect_charges": {
    "state_diff_entry": {
      "base": 500,
      "per_32_bytes": 20,
      "note": "per StateDiff entry; total = 500 + 20 * ceil(value_bytes/32). A deletion (EMPTY sentinel) charges base only (value_bytes=0)."
    },
    "event": {
      "base": 100,
      "per_32_bytes": 10,
      "note": "per event; total = 100 + 10 * ceil(data_bytes/32). Topics are fixed 32-byte each and included in base accounting up to MaxTopicsPerEvent."
    },
    "outbox_message": {
      "base": 200,
      "per_32_bytes": 5,
      "note": "per outbox message; total = 200 + 5 * ceil(payload_bytes/32)."
    },
    "return_data": {
      "base": 10,
      "per_32_bytes": 2,
      "note": "charged once for ReturnData; total = 10 + 2 * ceil(return_bytes/32)."
    }
  },
  "out_of_gas": {
    "rule": "Gas is checked before each basic block and before each host call and before the post-execution effect charge. On exhaustion at any point the input fails OUT_OF_GAS with full rollback (SPEC.md §10.5)."
  },
  "ceil_helper": {
    "definition": "ceil(n/32) = (n + 31) // 32",
    "applies_to": [
      "storage_read",
      "state_diff_entry",
      "event",
      "outbox_message",
      "return_data"
    ]
  }
}